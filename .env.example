DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
# Local dev (single Postgres instance, no pooling) can just mirror DATABASE_URL.
# In production (Prisma Postgres), this must be the direct (non-pooled) connection
# string, while DATABASE_URL is the pooled one used by the app at runtime.
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"
ADMIN_PASSWORD="changeme"
